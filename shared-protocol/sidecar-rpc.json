{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Perf Lens Sidecar RPC Protocol",
  "description": "JSON-RPC 2.0 schema for communication between the VS Code extension and the C++ analysis sidecar.",
  "version": "0.1.0",
  "definitions": {
    "RpcRequest": {
      "type": "object",
      "required": ["jsonrpc", "id", "method"],
      "properties": {
        "jsonrpc": { "type": "string", "const": "2.0" },
        "id": { "oneOf": [{ "type": "string" }, { "type": "number" }] },
        "method": { "type": "string" },
        "params": {}
      }
    },
    "RpcNotification": {
      "type": "object",
      "required": ["jsonrpc", "method"],
      "properties": {
        "jsonrpc": { "type": "string", "const": "2.0" },
        "method": { "type": "string" },
        "params": {}
      }
    },
    "RpcResponse": {
      "type": "object",
      "required": ["jsonrpc", "id"],
      "properties": {
        "jsonrpc": { "type": "string", "const": "2.0" },
        "id": { "oneOf": [{ "type": "string" }, { "type": "number" }, { "type": "null" }] },
        "result": {},
        "error": {
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "type": "integer" },
            "message": { "type": "string" },
            "data": {}
          }
        }
      }
    },
    "PingParams": {
      "type": "object",
      "description": "No parameters required."
    },
    "PingResult": {
      "type": "object",
      "required": ["pong"],
      "properties": {
        "pong": { "type": "boolean", "const": true }
      }
    },
    "EchoParams": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" }
      }
    },
    "EchoResult": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": { "type": "string" }
      }
    },
    "ReadyNotification": {
      "description": "Sent by the sidecar immediately after startup. The extension must wait for this before sending requests.",
      "type": "object",
      "required": ["jsonrpc", "method", "params"],
      "properties": {
        "jsonrpc": { "type": "string", "const": "2.0" },
        "method":  { "type": "string", "const": "ready" },
        "params": {
          "type": "object",
          "required": ["version", "pid"],
          "properties": {
            "version":      { "type": "string" },
            "pid":          { "type": "integer" },
            "capabilities": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    }
  },
  "methods": {
    "ping": {
      "description": "Health-check. Returns pong:true.",
      "params": { "$ref": "#/definitions/PingParams" },
      "result": { "$ref": "#/definitions/PingResult" }
    },
    "echo": {
      "description": "Returns the message unchanged. Used for RPC smoke-testing.",
      "params": { "$ref": "#/definitions/EchoParams" },
      "result": { "$ref": "#/definitions/EchoResult" }
    }
  },
  "notifications": {
    "ready": { "$ref": "#/definitions/ReadyNotification" }
  }
}
