{
  "name": "perf-lens",
  "displayName": "Perf Lens",
  "description": "C++ performance advisor: static analysis, compiler remarks, and profile-guided optimisation — all in VS Code.",
  "version": "1.0.0",
  "publisher": "perf-lens",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Linters", "Other"],
  "activationEvents": [
    "onLanguage:cpp",
    "onLanguage:c",
    "workspaceContains:**/compile_commands.json",
    "workspaceContains:**/CMakeLists.txt"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "perfLens",
          "title": "Perf Lens",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "perfLens": [
        {
          "id": "perfLens.remarks",
          "name": "Compiler Remarks",
          "when": "perf-lens:active"
        }
      ]
    },
    "commands": [
      {
        "command": "perfLens.analyseFile",
        "title": "Perf Lens: Analyse This File"
      },
      {
        "command": "perfLens.showPerfPanel",
        "title": "Perf Lens: Show Performance Panel"
      },
      {
        "command": "perfLens.regenerateRemarks",
        "title": "Perf Lens: Regenerate Remarks for This File",
        "icon": "$(refresh)"
      },
      {
        "command": "perfLens.goToRemark",
        "title": "Perf Lens: Go to Remark"
      },
      {
        "command": "perfLens.translateRemark",
        "title": "Perf Lens: Translate Remark with AI"
      },
      {
        "command": "perfLens.explainFinding",
        "title": "Perf Lens: Explain Finding with AI"
      },
      {
        "command": "perfLens.clearLLMCache",
        "title": "Perf Lens: Clear LLM Cache"
      },
      {
        "command": "perfLens.applyFix",
        "title": "Perf Lens: Apply Fix"
      },
      {
        "command": "perfLens.verifyFix",
        "title": "Perf Lens: Verify Fix (Preview Asm Diff)"
      },
      {
        "command": "perfLens.showCacheLineLayout",
        "title": "Perf Lens: Show Cache-Line Layout"
      },
      {
        "command": "perfLens.openLoopAnalyser",
        "title": "Perf Lens: Open Loop Analyser"
      },
      {
        "command": "perfLens.showProfilePanel",
        "title": "Perf Lens: Show Profile Panel"
      },
      {
        "command": "perfLens.importProfile",
        "title": "Perf Lens: Import Profile…"
      },
      {
        "command": "perfLens.recordProfile",
        "title": "Perf Lens: Record Profile…"
      },
      {
        "command": "perfLens.compareProfiles",
        "title": "Perf Lens: Compare Profiles…"
      },
      {
        "command": "perfLens.synthesiseHotness",
        "title": "Perf Lens: Synthesise Top Recommendations (AI)"
      },
      {
        "command": "perfLens.exportSarif",
        "title": "Perf Lens: Export Findings as SARIF…"
      },
      {
        "command": "perfLens.diagnosticBundle",
        "title": "Perf Lens: Export Diagnostic Bundle…"
      },
      {
        "command": "perfLens.configureLLM",
        "title": "Perf Lens: Configure LLM Provider…"
      },
      {
        "command": "perfLens.profileDiffJson",
        "title": "Perf Lens: Export Profile Diff as JSON…"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "perfLens.regenerateRemarks",
          "when": "resourceLangId == cpp || resourceLangId == c",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Perf Lens",
      "properties": {
        "perfLens.analyseOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically analyse files on save."
        },
        "perfLens.analyseOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Automatically analyse files when opened."
        },
        "perfLens.minConfidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "default": "medium",
          "description": "Minimum confidence level for displayed findings."
        },
        "perfLens.llm.primary": {
          "type": "string",
          "default": "",
          "description": "Primary LLM provider in the form 'provider:model' (e.g. 'ollama:qwen2.5-coder:7b')."
        },
        "perfLens.llm.providers": {
          "type": "array",
          "default": [],
          "description": "List of LLM provider configurations.",
          "items": {
            "type": "object",
            "required": ["id", "type", "model"],
            "properties": {
              "id":      { "type": "string", "description": "Unique identifier for this provider." },
              "type":    { "type": "string", "enum": ["ollama", "openai-compat", "anthropic", "openai"], "description": "Provider type." },
              "model":   { "type": "string", "description": "Model name." },
              "baseUrl": { "type": "string", "description": "Base URL (for ollama and openai-compat)." },
              "apiKey":  { "type": "string", "description": "API key (for anthropic, openai, openai-compat)." },
              "isLocal": { "type": "boolean", "description": "Override local flag (for openai-compat pointing at a local server)." }
            }
          }
        },
        "perfLens.llm.allowRemote": {
          "type": "boolean",
          "default": false,
          "description": "Allow using remote (non-local) LLM providers. When false, only Ollama and other local providers are used."
        },
        "perfLens.llm.budgetUSD": {
          "type": "number",
          "description": "Monthly spend limit in USD for remote LLM providers. The router will not send calls that would exceed this budget."
        },
        "perfLens.llm.warnAtPercent": {
          "type": "number",
          "default": 80,
          "description": "Show a warning in the status bar when this percentage of the budget has been consumed."
        },
        "perfLens.godbolt.extraFlags": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["-O2", "-std=c++20"],
          "description": "Extra flags passed to the compiler when compiling snippets for verification and the Loop Analyser."
        },
        "perfLens.compiler.path": {
          "type": "string",
          "default": "",
          "description": "Path to the C++ compiler (empty = auto-detect from PATH)."
        },
        "perfLens.godbolt.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable opt-in integration with godbolt.org."
        },
        "perfLens.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Send anonymous usage statistics (off by default)."
        },
        "perfLens.ui.showGutterHeatmap": {
          "type": "boolean",
          "default": true,
          "description": "Show hotness heatmap in the editor gutter when a profile is loaded."
        },
        "perfLens.ui.maxFindingsPerFile": {
          "type": "number",
          "default": 50,
          "description": "Maximum number of findings shown per file."
        }
      }
    }
  },
  "scripts": {
    "dev": "pnpm run build && code --extensionDevelopmentPath=$(pwd)",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node20 --sourcemap",
    "watch": "pnpm run build -- --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "moduleNameMapper": {
      "^vscode$": "<rootDir>/src/__mocks__/vscode.ts"
    }
  }
}
